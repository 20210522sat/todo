<body>
<div class="card">
  <div class="topbar">
    <span class="app-title">共享代辦事項</span>
    <span class="badge" id="count">0</span>
  </div>

  <div class="sync-bar">
    <span class="dot" id="sync-dot"></span>
    <span id="sync-label">連線中...</span>
  </div>

  <div class="name-row">
    <span class="name-label">你的名稱：</span>
    <input class="name-input" id="user-name" type="text" placeholder="匿名" maxlength="12">
  </div>

  <div class="input-row">
    <input class="task-input" id="new-task" type="text" placeholder="新增任務…" maxlength="80">
    <button class="add-btn" onclick="addTask()">新增</button>
  </div>

  <div id="todo-section">
    <div class="section-label">待完成</div>
    <div class="todo-list" id="todo-list"><div class="loading">載入中...</div></div>
  </div>

  <div id="done-section" style="display:none">
    <div class="section-label">已完成</div>
    <div class="todo-list" id="done-list"></div>
    <button class="clear-btn" onclick="clearDone()">清除已完成</button>
  </div>
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getDatabase, ref, push, update, remove, onValue, query, orderByChild } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSyBkKAGUnB1YYzlaUHrNFQGZ7UDDWB9KCLQ",
  authDomain: "todo-e6269.firebaseapp.com",
  databaseURL: "https://todo-e6269-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "todo-e6269",
  storageBucket: "todo-e6269.firebasestorage.app",
  messagingSenderId: "892861599023",
  appId: "1:892861599023:web:a77c7e77fa69734dbca5da"
};

const app = initializeApp(firebaseConfig);
const db = getDatabase(app);
const todosRef = ref(db, 'todos');

const dot = document.getElementById('sync-dot');
const syncLabel = document.getElementById('sync-label');

function userName(){ return document.getElementById('user-name').value.trim() || '匿名'; }

function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function itemHTML(key, t){
  const metaLine = [t.by, t.at].filter(Boolean).join(' ');
  return `<div class="todo-item${t.done?' done':''}" id="item-${key}">
    <button class="check-btn${t.done?' checked':''}" onclick="toggleTask('${key}',${!t.done})">
      <svg class="check-icon" viewBox="0 0 10 10"><polyline points="1.5,5 4,7.5 8.5,2.5"/></svg>
    </button>
    <span class="todo-text">${esc(t.text)}</span>
    <span class="meta">${esc(metaLine)}</span>
    <button class="del-btn" onclick="delTask('${key}')">×</button>
  </div>`;
}

function render(tasks){
  const todo = tasks.filter(([,t])=>!t.done).reverse();
  const done = tasks.filter(([,t])=>t.done).reverse();

  document.getElementById('count').textContent = todo.length;
  document.getElementById('todo-list').innerHTML = todo.length
    ? todo.map(([k,t])=>itemHTML(k,t)).join('')
    : '<div class="empty">沒有待完成任務</div>';
  document.getElementById('done-list').innerHTML = done.map(([k,t])=>itemHTML(k,t)).join('');
  document.getElementById('done-section').style.display = done.length ? '' : 'none';
}

onValue(query(todosRef, orderByChild('createdAt')), (snapshot) => {
  dot.className = 'dot online';
  syncLabel.textContent = '即時同步中 — 所有人看到一樣的清單';
  const val = snapshot.val() || {};
  const tasks = Object.entries(val);
  render(tasks);
}, (err) => {
  dot.className = 'dot error';
  syncLabel.textContent = '連線失敗，請重新整理';
});

window.addTask = async function(){
  const input = document.getElementById('new-task');
  const text = input.value.trim();
  if(!text) return;
  input.value = '';
  await push(todosRef, {
    text,
    done: false,
    by: userName(),
    at: new Date().toLocaleTimeString('zh-TW',{hour:'2-digit',minute:'2-digit'}),
    createdAt: Date.now()
  });
  input.focus();
};

window.toggleTask = async function(key, newVal){
  await update(ref(db, 'todos/'+key), { done: newVal });
};

window.delTask = async function(key){
  await remove(ref(db, 'todos/'+key));
};

window.clearDone = async function(){
  const snap = await new Promise(res => onValue(todosRef, res, {onlyOnce:true}));
  const val = snap.val() || {};
  const updates = {};
  Object.entries(val).forEach(([k,t])=>{ if(t.done) updates['todos/'+k]=null; });
  if(Object.keys(updates).length) await update(ref(db), updates);
};

document.getElementById('new-task').addEventListener('keydown', e => {
  if(e.key==='Enter') window.addTask();
});

const savedName = localStorage.getItem('todo_username');
if(savedName) document.getElementById('user-name').value = savedName;
document.getElementById('user-name').addEventListener('input', e => {
  localStorage.setItem('todo_username', e.target.value);
});
</script>
</body>
